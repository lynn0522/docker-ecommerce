# ============================================
# Docker Compose 环境变量
# ============================================

# 应用基础配置
APP_NAME=ecommerce
APP_VERSION=1.0.0
APP_PORT=8084  # 改：避免端口冲突，用8084（原8080可能被占用）

# 新增：PhpMyAdmin端口
PMA_PORT=8081
# Spring Boot 配置
SPRING_PROFILES_ACTIVE=docker
SPRING_APPLICATION_NAME=ecommerce-backend

# 数据库配置（关键：和你application.properties匹配）
DB_HOST=mysql
DB_PORT=3306
DB_NAME=ecommerce  # 改：和你application.properties的库名一致（原ecommerce_db→ecommerce）
# DB_USERNAME=root   # 改：用root用户（原appuser，和你MySQL配置一致）
DB_PASSWORD=123456 # 改：和你MySQL密码一致（原apppassword123→123456）
MYSQL_ROOT_PASSWORD=123456 # 改：root密码统一为123456

# MySQL优化参数
MYSQL_MAX_CONNECTIONS=1000
MYSQL_INNODB_BUFFER_POOL_SIZE=256M
MYSQL_CHARACTER_SET_SERVER=utf8mb4
MYSQL_COLLATION_SERVER=utf8mb4_unicode_ci

# Java虚拟机配置
JAVA_OPTS=-Xmx512m -Xms256m -XX:+UseG1GC -XX:MaxGCPauseMillis=200 -XX:+HeapDumpOnOutOfMemoryError -XX:HeapDumpPath=/tmp
JAVA_TOOL_OPTIONS=-Dfile.encoding=UTF-8 -Duser.timezone=Asia/Shanghai

# 时区配置
TZ=Asia/Shanghai

# 监控配置
MANAGEMENT_ENDPOINTS_WEB_EXPOSURE_INCLUDE=health,info,metrics,prometheus
MANAGEMENT_ENDPOINT_HEALTH_SHOW_DETAILS=always
MANAGEMENT_METRICS_EXPORT_PROMETHEUS_ENABLED=true

# 网络配置
NETWORK_NAME=ecommerce-network

# 日志配置
LOG_LEVEL=INFO
LOG_PATH=/var/log/ecommerce