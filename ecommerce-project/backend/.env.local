# ============================================
# 本地开发环境变量
# ============================================

# 本地MySQL配置
DB_HOST=localhost
DB_PORT=3306
DB_NAME=ecommerce_local
DB_USERNAME=root
DB_PASSWORD=your_local_password

# 开发配置
SPRING_PROFILES_ACTIVE=dev
SPRING_DEVTOOLS_RESTART_ENABLED=true

# Java开发选项
JAVA_OPTS=-Xmx512m -Xms256m -XX:+HeapDumpOnOutOfMemoryError